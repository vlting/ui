{
  "name": "@vlting/stl-native",
  "version": "0.0.1",
  "type": "module",
  "author": "Lucas Castro <lucas.castro@gmail.com>",
  "description": "React Native bindings for the STL styling engine",
  "main": "dist/stl-native.js",
  "module": "dist/stl-native.es.js",
  "types": "dist/index.d.ts",
  "typings": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "private": false,
  "directories": {
    "dist": "dist"
  },
  "files": ["dist", "src"],
  "exports": {
    ".": {
      "import": "./dist/stl-native.es.js",
      "require": "./dist/stl-native.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build:js": "vite build",
    "build": "yarn build:js",
    "watch": "vite build --watch",
    "build:lib": "yarn build",
    "watch:lib": "yarn watch",
    "lint": "eslint --ignore-path .gitignore --ext .js,.ts,.tsx .",
    "test": "node node_modules/vitest/vitest.mjs run",
    "test:watch": "node node_modules/vitest/vitest.mjs"
  },
  "bugs": {
    "url": "https://github.com/vlting/ui/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vlting/ui.git"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "20.12.12",
    "@types/react": "18.3.2",
    "@typescript-eslint/eslint-plugin": "7.9.0",
    "@typescript-eslint/parser": "7.9.0",
    "eslint": "9.2.0",
    "eslint-config-prettier": "9.x",
    "prettier": "3.x",
    "pretty-quick": "4.x",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "@testing-library/react-native": "^12.0.0",
    "react-dom": "^18.0.0",
    "react-test-renderer": "^18.0.0",
    "vite-plugin-dts": "^3.9.1",
    "vitest": "^3.0.0"
  }
}
